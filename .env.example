# Copy this file to .env and paste your key:
#     cp .env.example .env
# .env is gitignored — it is never committed.
#
# One credential reaches EVERY model and the judge: OpenRouter is an
# OpenAI-compatible gateway, so a single key fans out to Anthropic, OpenAI,
# Google, open models, etc. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
